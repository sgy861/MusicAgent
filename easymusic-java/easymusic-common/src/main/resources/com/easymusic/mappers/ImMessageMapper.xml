            receiver_id = VALUES(receiver_id),
            msg_type = VALUES(msg_type),
            content = VALUES(content),
            status = VALUES(status),
            update_time = VALUES(update_time)
    </insert>

    <!-- 多条件修改 -->
    <update id="updateByParam" parameterType="com.easymusic.entity.query.ImMessageQuery">
        UPDATE im_message m
        <set>
            <if test="bean.senderId != null">
                m.sender_id = #{bean.senderId},
            </if>
            <if test="bean.receiverId != null">
                m.receiver_id = #{bean.receiverId},
            </if>
            <if test="bean.msgType != null">
                m.msg_type = #{bean.msgType},
            </if>
            <if test="bean.content != null">
                m.content = #{bean.content},
            </if>
            <if test="bean.status != null">
                m.status = #{bean.status},
            </if>
            <if test="bean.updateTime != null">
                m.update_time = #{bean.updateTime},
            </if>
        </set>
        <include refid="query_condition"/>
    </update>

    <!-- 根据PrimaryKey获取对象 -->
    <select id="selectByMessageId" resultMap="base_result_map">
        SELECT <include refid="base_column_list"/> FROM im_message m WHERE m.message_id = #{messageId}
    </select>

    <!-- 根据PrimaryKey修改 -->
    <update id="updateByMessageId" parameterType="com.easymusic.entity.po.ImMessage">
        UPDATE im_message
        <set>
            <if test="bean.senderId != null">
                sender_id = #{bean.senderId},
            </if>
            <if test="bean.receiverId != null">
                receiver_id = #{bean.receiverId},
            </if>
            <if test="bean.msgType != null">
                msg_type = #{bean.msgType},
            </if>
            <if test="bean.content != null">
                content = #{bean.content},
            </if>
            <if test="bean.status != null">
                status = #{bean.status},
            </if>
            <if test="bean.updateTime != null">
                update_time = #{bean.updateTime},
            </if>
        </set>
        WHERE message_id = #{messageId}
    </update>

    <!-- 根据PrimaryKey删除 -->
    <delete id="deleteByMessageId">
        DELETE FROM im_message WHERE message_id = #{messageId}
    </delete>

</mapper>
